<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <EditText
        android:id="@+id/nameInput"
        android:autofillHints="name"
        android:hint="@string/enter_student_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPersonName"
        android:layout_marginTop="48dp"
        android:padding="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:textColorHint="@color/text_dark"  />

    <EditText
        android:id="@+id/scoreInput"
        android:autofillHints="none"
        android:hint="@string/enter_score"
        android:inputType="numberDecimal"
        android:layout_marginTop="48dp"
        android:layout_width="match_parent"
        android:padding="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/calcButton"
        android:text="@string/calculate_grade"
        android:layout_marginTop="48dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:padding="12dp"/>

    <TextView
        android:id="@+id/resultText"
        android:text="@string/result_placeholder"
        android:textSize="20sp"
        android:textColor="@color/text_dark"
        android:layout_marginTop="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:padding="12dp" />

</LinearLayout>